#column prg
import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    int num=sc.nextInt();
	    int nums=1;
	    for(int col=0;col<=num;col++){
	        for(int row=0;row<=num;row++){
	            System.out.println(nums+" ");
	            nums++;
	        }
	        System.out.println();
	    }
		
	}
}

#rightangle triangle
import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    int num=sc.nextInt();
	    int nums=1;
	    for(int col=0;col<=num;col++){
	        for(int row=0;row<=col;row++){
	            System.out.print("* ");
	            nums++;
	        }
	        System.out.println();
	    }
		
	}
}

#alphabets triangle
import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    int num=sc.nextInt();
	    char ch='A';
	    for(int col=0;col<=num;col++){
	        ch='A';
	        for(int row=0;row<=col;row++){
	            System.out.print(ch+" ");
	            ch++;
	        }
	        System.out.println();
	    }
		
	}
}


 
