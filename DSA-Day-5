import java.io.*; 

public class Main { 
    public static void main(String[] args) { 
        String s="killer the boy";
        int left=0;
        int right=s.length()-1;
        while(left<right){
            char temp=s[left];
            s[left]=s[right];
            s[right]=temp;
            left++;
            right--;
        }
    } 
}

#palindrom
class Solution {
    boolean isPalindrome(String s) {
        // code here
        int left=0;
        int right=s.length()-1;
        while(left<right){
            if(s.charAt(left)!= s.charAt(right)){
                return false;
            }
            left++;
            right--;
        }
        return true;
        
    }
}

